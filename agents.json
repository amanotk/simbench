{
  "version": 1,
  "agents": {
    "opencode": {
      "bins": [
        {
          "host": "opencode",
          "container": "/usr/local/bin/opencode"
        }
      ],
      "mounts": [
        {
          "host": "~/.local/share/opencode/auth.json",
          "container": "/opencode-auth.json",
          "mode": "ro",
          "optional": true
        }
      ],
      "pass_env": [
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "OPENROUTER_API_KEY",
        "GITHUB_TOKEN",
        "AZURE_OPENAI_API_KEY",
        "AZURE_OPENAI_ENDPOINT",
        "AZURE_OPENAI_API_VERSION"
      ],
      "env": {
        "OPENCODE_DISABLE_AUTOUPDATE": "1"
      },
      "pre": [
        "mkdir -p \"$HOME/.local/share/opencode\"",
        "if [ -f /opencode-auth.json ]; then cp /opencode-auth.json \"$HOME/.local/share/opencode/auth.json\"; fi"
      ],
      "cmd": "opencode run -m \"$BENCH_MODEL\" --dir /work \"$(cat /run/prompt.txt)\" -f /run/spec.md"
    },
    "claude-code": {
      "enabled": false,
      "bins": [
        {
          "host": "claude",
          "container": "/usr/local/bin/claude"
        }
      ],
      "mounts": [],
      "pass_env": [
        "ANTHROPIC_API_KEY"
      ],
      "pre": [],
      "cmd": "claude --help"
    },
    "codex": {
      "enabled": false,
      "bins": [
        {
          "host": "codex",
          "container": "/usr/local/bin/codex"
        }
      ],
      "mounts": [],
      "pass_env": [
        "OPENAI_API_KEY"
      ],
      "pre": [],
      "cmd": "codex --help"
    },
    "gh-copilot": {
      "enabled": false,
      "bins": [
        {
          "host": "gh",
          "container": "/usr/local/bin/gh"
        }
      ],
      "mounts": [
        {
          "host": "~/.config/gh",
          "container": "/tmp/.config/gh",
          "mode": "ro",
          "optional": true
        }
      ],
      "pass_env": [
        "GITHUB_TOKEN"
      ],
      "pre": [],
      "cmd": "gh copilot --help"
    }
  }
}
